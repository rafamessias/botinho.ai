rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAcceptedCompanyMember(companyId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid)).data.status == 'accepted';
    }

    match /users/{userId} {
      allow read, write: if false;
    }

    match /companies/{companyId} {
      allow read, write: if false;

      match /members/{memberId} {
        allow read, write: if false;
      }

      match /settings/{docId} {
        allow read, write: if false;
      }

      match /subscription/{docId} {
        allow read, write: if false;
      }

      match /usage/{docId} {
        allow read, write: if false;
      }

      match /channelUsage/{docId} {
        allow read, write: if false;
      }

      match /inboundEvents/{docId} {
        allow read, write: if false;
      }

      match /messageDedupe/{docId} {
        allow read, write: if false;
      }

      match /knowledge/{docId} {
        allow read, write: if false;
      }

      match /quickAnswers/{docId} {
        allow read, write: if false;
      }

      match /templates/{docId} {
        allow read, write: if false;
      }

      match /surveys/{docId} {
        allow read, write: if false;
      }

      match /surveyResponses/{docId} {
        allow read, write: if false;
      }

      match /campaigns/{docId} {
        allow read, write: if false;
      }

      match /campaignDeliveries/{docId} {
        allow read, write: if false;
      }

      match /customers/{docId} {
        allow read, write: if false;
      }

      match /tickets/{ticketId} {
        allow read, write: if false;

        match /comments/{docId} {
          allow read, write: if false;
        }

        match /activities/{docId} {
          allow read, write: if false;
        }
      }

      match /ticketCounters/{docId} {
        allow read, write: if false;
      }

      match /conversations/{conversationId} {
        allow read: if isAcceptedCompanyMember(companyId);
        allow write: if false;

        match /messages/{messageId} {
          allow read: if isAcceptedCompanyMember(companyId);
          allow write: if false;
        }
      }
    }

    match /plans/{planId} {
      allow read: if true;
      allow write: if false;
    }

    match /pendingSignups/{docId} {
      allow read, write: if false;
    }

    match /systemProperties/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
