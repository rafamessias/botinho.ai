# ENV
NODE_ENV="development"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Support contact (contact form destination)
SUPPORT_EMAIL=hello@botinho.ai

# OTP
OTP_ENABLED="TRUE"

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google Auth (NextAuth OAuth)
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Firebase Client (public)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server) — JSON string of service account
# Firebase Console > Project Settings > Service Accounts > Generate new private key
# Paste the full JSON on one line (keep \\n in private_key as-is)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Firebase AI Logic (Gemini) — enable in Firebase console: npx firebase-tools@latest init ailogic
# Uses Gemini Developer API via Firebase; no separate GEMINI_API_KEY needed
