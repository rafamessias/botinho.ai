# ENV
NODE_ENV="development"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# URL the WhatsApp worker uses to POST inbound webhooks (Docker: host.docker.internal)
WEBHOOK_APP_URL="http://host.docker.internal:3000"

# Support contact (contact form destination)
SUPPORT_EMAIL=hello@botinho.ai

# OTP
OTP_ENABLED="TRUE"

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google Auth (NextAuth OAuth)
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Firebase Client (public)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server) — JSON string of service account
# Firebase Console > Project Settings > Service Accounts > Generate new private key
# Paste the full JSON on one line (keep \\n in private_key as-is)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Google Gemini API — get your key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# WhatsApp worker + orchestration (Next.js app is the manager)
REDIS_URL=redis://localhost:6379
WORKER_INTERNAL_TOKEN=dev-worker-token
WHATSAPP_WEBHOOK_SECRET=dev-worker-token
MAX_SESSIONS_PER_WORKER=25
SCALER_MODE=local
WORKER_BASE_URL=http://localhost
# Host port for whatsapp-worker (8082 avoids stale docker-proxy on 8081 after WSL restarts)
WHATSAPP_WORKER_PORT=8082
# Optional — worker uses in-memory repo when unset; set to match Firebase project in production
FIRESTORE_PROJECT_ID=
# WhatsApp session store persistence (Phase 1 — see docs/spec/24-whatsapp-session-store-persistence.md)
# Worker snapshots whatsmeow SQLite to durable storage; Firestore waStores holds metadata per sessionId.
WA_STORE_BACKEND=local
WA_STORE_LOCAL_DIR=/data/wa-store-backups
WA_STORE_BUCKET=
WA_STORE_SNAPSHOT_INTERVAL=60s
WA_STORE_RETAIN_VERSIONS=3
SESSION_STORE_DIR=/data/sessions
# Skip WhatsApp history sync on pair (inbound-only). Overrides Firestore systemProperties when set.
WA_SKIP_HISTORY_SYNC=true
# When using `npm run dev:infra`, set WEBHOOK_APP_URL so the Docker worker can reach Next.js:
# WEBHOOK_APP_URL=http://host.docker.internal:3000

# Cron jobs — Google Cloud Scheduler hits these routes with Authorization: Bearer <CRON_SECRET>
# See docs/spec/22-scheduled-jobs.md
CRON_SECRET=
